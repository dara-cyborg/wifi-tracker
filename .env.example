# Admin Credentials (MUST CHANGE IN PRODUCTION!)
# Use a strong password: at least 16 characters with mixed case, numbers, special chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe_SecurePassword123!

# Telegram Configuration (Optional - only if using daily alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Security Settings
ENVIRONMENT=development
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=your_secret_key_here_generate_with_python

# CORS/Hosts Configuration
# For production, set to your domain (comma-separated for multiple)
ALLOWED_HOSTS=localhost,127.0.0.1

# Login Security
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
# Use sqlite:///./wifi_tracker.db for SQLite, or postgresql://... for PostgreSQL
DATABASE_URL=sqlite:///./wifi_tracker.db

# Bakong KHQR Payment Configuration
# Get token from Bakong developer dashboard
BAKONG_DEVELOPER_TOKEN=your_bakong_developer_token_here
# Bakong merchant account (usually email format)
BAKONG_MERCHANT_ACCOUNT_ID=your_merchant_account_id_here
# Merchant name displayed on QR code (13 characters max for KHQR)
BAKONG_MERCHANT_NAME=Your Merchant Name
# Merchant city for QR code
BAKONG_MERCHANT_CITY=Phnom Penh

# Pricing Configuration
# Price per unique device (MAC address) per month in USD
PRICE_PER_DEVICE_PER_MONTH=2.5

# Scheduler Configuration
# Timezone for scheduled jobs (e.g., Asia/Phnom_Penh)
SCHEDULER_TIMEZONE=Asia/Phnom_Penh
