# Admin Credentials (MUST CHANGE IN PRODUCTION!)
# Use a strong password: at least 16 characters with mixed case, numbers, special chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe_SecurePassword123!

# Telegram Configuration (Optional - only if using daily alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Security Settings
ENVIRONMENT=development
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=your_secret_key_here_generate_with_python

# CORS/Hosts Configuration
# For production, set to your domain (comma-separated for multiple)
ALLOWED_HOSTS=localhost,127.0.0.1

# Login Security
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Server Configuration
HOST=0.0.0.0
PORT=8000
